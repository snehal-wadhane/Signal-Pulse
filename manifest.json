{
  "manifest_version": 3,
  "name": "Signal Pulse - Workplace Wellness Monitor",
  "version": "1.0.0",
  "description": "Privacy-first digital signal analyzer for deep work and wellness tracking",
  "permissions": [
    "tabs",
    "idle",
    "storage",
    "notifications",
    "alarms",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
